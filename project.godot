; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SpaceShooterDotnet"
run/main_scene="uid://c8ivm86osl6ln"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*uid://exq1mdw2m2ok"
ScoreManager="*uid://b6aco4wg1lena"

[display]

window/size/viewport_width=360
window/size/viewport_height=640
window/size/resizable=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="SpaceShooterDotnet"

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="objects"
2d_physics/layer_3="projectile"
2d_physics/layer_4="player"
2d_physics/layer_5="player_hitbox"
2d_physics/layer_6="player_hurtbox"
2d_physics/layer_7="player_detection"
2d_physics/layer_8="enemy"
2d_physics/layer_9="enemy_hitbox"
2d_physics/layer_10="enemy_hurtbox"
2d_physics/layer_11="enemy_detection"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
